// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/generated/zod"
}



model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")

  accounts Account[]
  sessions Session[]

  // One user can be a recruiter (or not)
  recruiter Recruiter?
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Recruiter {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName  String
  website      String
  linkedinLink String
  verified     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  recruiterForms RecruiterForm[]
}


model Domains {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  title       String @unique
  description String
  jobCount    Int    @default(0)
  haveDefaultForm Boolean @default(false)
  isActive  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recruiterForms RecruiterForm[]
  defaultFormSchemas DefaultFormSchema[] 
}



model RecruiterForm {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  recruiterId String    @db.ObjectId
  recruiter   Recruiter @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  domainId String  @db.ObjectId
  domain   Domains @relation(fields: [domainId], references: [id], onDelete: Cascade)

  // Public job link
  publicId String @unique @default(uuid())

  // Job identity
  title       String
  description String

  // Hiring metadata
  roleType   RoleType // FullTime, Internship, Contract
  experience Experience // Junior, Mid, Senior, Lead
  workMode   WorkMode // Remote, Hybrid, Onsite

  location String? // City / Country if onsite or hybrid


  fields Json // role-based form schema

  expiresAt DateTime
  isActive  Boolean  @default(true)

  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([recruiterId])
  @@index([domainId])
  @@index([isActive])
}



model Role {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String  @unique
  isActive Boolean @default(true)

  fields FormField[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DefaultFormSchema {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  domainId String  @unique @db.ObjectId
  domain   Domains @relation(fields: [domainId], references: [id], onDelete: Cascade)

  version Int @default(1)

  fields Json

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}


model FormField {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  roleId String @db.ObjectId
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  label    String
  name     String
  type     String
  required Boolean  @default(false)
  options  String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@index([name])
}

model Application {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  jobId String        @db.ObjectId
  job   RecruiterForm @relation(fields: [jobId], references: [id], onDelete: Cascade)

  fullName String
  email    String
  phone    String?

  responses Json

  resumeUrl String?
  portfolio String?
  github    String?
  linkedin  String?

  status ApplicationStatus  @default(APPLIED)
  scores ApplicationScore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([email])
  @@index([status])
}

model ApplicationScore {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  applicationId String      @db.ObjectId
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Final computed score
  totalScore Float // 0 → 100

  // Breakdown (why the candidate got that score)
  breakdown Json
  /**
   * Example:
   * {
   * "github": 35,
   * "experience": 25,
   * "skills": 20,
   * "portfolio": 10,
   * "cultureFit": 10
   * }
   */

  evaluatedAt DateTime @default(now())

  @@index([applicationId])
  @@index([totalScore])
}


model EmailVerification {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}


enum RoleType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum Experience {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW
  REJECTED
  HIRED
}
