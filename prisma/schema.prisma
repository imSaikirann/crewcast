// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/generated/zod"
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")

  accounts Account[]
  sessions Session[]

  // One user can be a recruiter (or not)
  recruiter Recruiter?
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Recruiter {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName  String
  companyEmail String
  website      String
  linkedinLink String
  verified     Boolean @default(false)

  // PLAN & LIMITS
  plan           RecruiterPlan @default(STARTER)
  formLimit      Int           @default(3)
  activeFormCount Int          @default(0)
  totalFormsCount  Int         @default(0)
  
  totalFormsLimit   Int         @default(8)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recruiterForms RecruiterForm[]
  verification EmailVerification[]
}




model Domains {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  title           String  @unique
  description     String
  jobCount        Int     @default(0)
  haveDefaultForm Boolean @default(false)
  isActive        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recruiterForms     RecruiterForm[]
  defaultFormSchemas DefaultFormSchema[]
}

model RecruiterForm {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  recruiterId String @db.ObjectId
  recruiter   Recruiter @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  domainId String @db.ObjectId
  domain   Domains @relation(fields: [domainId], references: [id], onDelete: Cascade)

  publicId String @unique @default(uuid())

  // Job identity
  title          String
  description    String
  specialization String

  // Hiring metadata
  roleType   RoleType
  experience Experience
  workMode   WorkMode
  location   String?

  // Salary
  salaryMin Int?
  salaryMax Int?
  currency  String?

  // Tech
  techStack String[]
  openings  Int      @default(1)

  // Contract
  contractDurationMonths Int?

  // Public visibility
  showCompanyName Boolean @default(true)

  // Versioning
  status      JobStatus @default(DRAFT)
  version     Int       @default(1)
  publishedAt DateTime?

  // Form schema
  fields Json

  expiresAt DateTime

  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reportCount Int     @default(0)
  isFlagged   Boolean @default(false)

  viewCount Int        @default(0)
  views     FormView[]

  jobReport JobReport[]

  @@index([recruiterId])
  @@index([domainId])
  @@index([status])
}

model FormView {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  formId String        @db.ObjectId
  form   RecruiterForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([formId])
  @@index([ip])
}

model JobReport {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  formId String       
  form   RecruiterForm @relation(fields: [formId], references: [publicId], onDelete: Cascade)

  reason  String
  message String?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([formId])
}

model Role {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String  @unique
  isActive Boolean @default(true)

  fields FormField[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DefaultFormSchema {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  domainId String  @unique @db.ObjectId
  domain   Domains @relation(fields: [domainId], references: [id], onDelete: Cascade)

  version Int @default(1)

  fields Json

  isActive Boolean @default(true)
  isForSoftwareRoles Boolean


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FormField {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  roleId String @db.ObjectId
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  label    String
  name     String
  type     String
  required Boolean  @default(false)
  options  String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@index([name])
}

model Application {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  trackingToken String @unique @default(uuid())

  jobId String        @db.ObjectId
  job   RecruiterForm @relation(fields: [jobId], references: [id], onDelete: Cascade)

  fullName String
  email    String


  responses Json


  status ApplicationStatus  @default(APPLIED)
  scores ApplicationScore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, email]) 
  @@index([jobId])
  @@index([email])
  @@index([status])
}

model ApplicationScore {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  applicationId String      @db.ObjectId
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Final computed score
  totalScore Float // 0 → 100

  // Breakdown (why the candidate got that score)
  breakdown Json
  /**
   * Example:
   * {
   * "github": 35,
   * "experience": 25,
   * "skills": 20,
   * "portfolio": 10,
   * "cultureFit": 10
   * }
   */

  evaluatedAt DateTime @default(now())

  @@index([applicationId])
  @@index([totalScore])
}

model EmailVerification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user Recruiter @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model UpgradeRequest {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  email      String
  company    String
  plan       String
  status     String   @default("PENDING") 
  createdAt  DateTime @default(now())
}

enum RoleType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum Experience {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum RecruiterPlan {
  STARTER     
  HIRING      
  SCALE       
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW
  REJECTED
  HIRED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
